<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ded_primary_variables_scss" model="ir.asset">
        <field name="name">D&amp;D Partners Primary Variables SCSS</field>
        <field name="key">theme_ded_partners.primary_variables_scss</field>
        <field name="bundle">web._assets_primary_variables</field>
        <field name="path">theme_ded_partners/static/src/scss/primary_variables.scss</field>
    </record>

    <record id="ded_bootstrap_overridden_scss" model="ir.asset">
        <field name="name">D&amp;D Partners Bootstrap Overridden SCSS</field>
        <field name="key">theme_ded_partners.bootstrap_overridden_scss</field>
        <field name="bundle" directive="prepend">web._assets_frontend_helpers</field>
        <field name="path">theme_ded_partners/static/src/scss/bootstrap_overridden.scss</field>
    </record>

    <record id="ded_theme_scss" model="ir.asset">
        <field name="name">D&amp;D Partners Theme SCSS</field>
        <field name="key">theme_ded_partners.theme_scss</field>
        <field name="bundle">website.assets_frontend</field>
        <field name="path">theme_ded_partners/static/src/scss/theme.scss</field>
    </record>

    <record id="ded_effects_js" model="ir.asset">
        <field name="name">D&amp;D Partners Effects JS</field>
        <field name="key">theme_ded_partners.effects_js</field>
        <field name="bundle">website.assets_frontend</field>
        <field name="path">theme_ded_partners/static/src/js/ded_effects.js</field>
    </record>

</odoo>
