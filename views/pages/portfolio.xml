<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="ded_portfolio_page" model="website.page">
    <field name="name">Portfolio</field>
    <field name="url">/portfolio</field>
    <field name="website_published">True</field>
    <field name="view_id" ref="ded_portfolio_view"/>
</record>

<record id="ded_portfolio_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners - Portfolio</field>
    <field name="type">qweb</field>
    <field name="key">theme_ded_partners.portfolio</field>
    <field name="arch" type="xml">
<t t-call="website.layout">
<div id="wrap" class="oe_structure oe_empty">

    <!-- Hero -->
    <section class="ded-hero" style="min-height:50vh;">
        <canvas id="ded-particle-canvas" class="particle-canvas" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"/>
        <div class="container" style="position:relative;z-index:1;padding-top:9rem;padding-bottom:5rem;">
            <div class="text-center">
                <span class="section-label">// portfolio</span>
                <h1 class="display-1 text-white mb-3">I Nostri <span class="text-gradient">Progetti</span></h1>
                <p style="color:rgba(255,255,255,.6);font-size:1.2rem;max-width:600px;margin:0 auto;">
                    Ogni progetto è una storia di trasformazione digitale.
                    Ecco alcune delle soluzioni che abbiamo realizzato.
                </p>
            </div>
        </div>
    </section>

    <!-- Filter tabs -->
    <section style="background:var(--ded-bg-mid);padding:1.5rem 0;border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);">
        <div class="container">
            <div class="d-flex flex-wrap gap-2 justify-content-center">
                <button class="btn btn-primary btn-sm" onclick="filterPortfolio('all')">Tutti</button>
                <button class="btn btn-glass btn-sm" onclick="filterPortfolio('ai')">AI &amp; Automazione</button>
                <button class="btn btn-glass btn-sm" onclick="filterPortfolio('odoo')">Odoo</button>
                <button class="btn btn-glass btn-sm" onclick="filterPortfolio('web')">Web App</button>
                <button class="btn btn-glass btn-sm" onclick="filterPortfolio('mobile')">Mobile</button>
                <button class="btn btn-glass btn-sm" onclick="filterPortfolio('pa')">Pubblica Amministrazione</button>
                <button class="btn btn-glass btn-sm" onclick="filterPortfolio('healthcare')">Healthcare</button>
            </div>
        </div>
    </section>

    <!-- Projects Grid -->
    <section class="ded-section ded-section-dark">
        <div class="container">
            <div class="row g-4">
                <!-- Project 1: AI Agent PA -->
                <div class="col-md-6 col-lg-4" data-ded-reveal="up" data-ded-delay="1" data-category="ai pa">
                    <div class="ded-card overflow-hidden h-100">
                        <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#1B3C73,#2563EB);display:flex;align-items:center;justify-content:center;font-size:4rem;">🏛️</div>
                        <div class="p-4">
                            <div class="d-flex gap-2 mb-2">
                                <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">AI</span>
                                <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">PA</span>
                            </div>
                            <h5 class="text-white mb-2">AI Agent per Comune</h5>
                            <p style="color:rgba(255,255,255,.55);font-size:.9rem;line-height:1.6;">
                                Agente AI per la gestione automatica delle pratiche amministrative
                                e risposta ai cittadini 24/7.
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Project 2: Odoo Healthcare -->
                <div class="col-md-6 col-lg-4" data-ded-reveal="up" data-ded-delay="2" data-category="odoo healthcare">
                    <div class="ded-card overflow-hidden h-100">
                        <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#224,#E07B1A33);display:flex;align-items:center;justify-content:center;font-size:4rem;">🏥</div>
                        <div class="p-4">
                            <div class="d-flex gap-2 mb-2">
                                <span style="background:rgba(224,123,26,.15);color:#FCD34D;border:1px solid rgba(224,123,26,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">Odoo</span>
                                <span style="background:rgba(224,123,26,.15);color:#FCD34D;border:1px solid rgba(224,123,26,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">Healthcare</span>
                            </div>
                            <h5 class="text-white mb-2">ERP Sanitario su Odoo</h5>
                            <p style="color:rgba(255,255,255,.55);font-size:.9rem;line-height:1.6;">
                                Sistema di gestione completo per struttura sanitaria privata.
                                Pazienti, appuntamenti, fatturazione integrata.
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Project 3: Dashboard BI -->
                <div class="col-md-6 col-lg-4" data-ded-reveal="up" data-ded-delay="3" data-category="web ai">
                    <div class="ded-card overflow-hidden h-100">
                        <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#0F2354,#1D4ED8);display:flex;align-items:center;justify-content:center;font-size:4rem;">📊</div>
                        <div class="p-4">
                            <div class="d-flex gap-2 mb-2">
                                <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">Web</span>
                                <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">Data</span>
                            </div>
                            <h5 class="text-white mb-2">Business Intelligence Dashboard</h5>
                            <p style="color:rgba(255,255,255,.55);font-size:.9rem;line-height:1.6;">
                                Dashboard interattiva per Regione Veneto.
                                KPI in tempo reale, report automatizzati e alert AI.
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Project 4: Mobile App -->
                <div class="col-md-6 col-lg-4" data-ded-reveal="up" data-ded-delay="1" data-category="mobile">
                    <div class="ded-card overflow-hidden h-100">
                        <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#1B3C73,#7C3AED);display:flex;align-items:center;justify-content:center;font-size:4rem;">📱</div>
                        <div class="p-4">
                            <div class="d-flex gap-2 mb-2">
                                <span style="background:rgba(124,58,237,.15);color:#C4B5FD;border:1px solid rgba(124,58,237,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">Mobile</span>
                            </div>
                            <h5 class="text-white mb-2">App Mobile Gestione Cantieri</h5>
                            <p style="color:rgba(255,255,255,.55);font-size:.9rem;line-height:1.6;">
                                App React Native per la gestione operativa di cantieri edili.
                                Offline-first, firma digitale, report istantanei.
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Project 5: Odoo E-Commerce -->
                <div class="col-md-6 col-lg-4" data-ded-reveal="up" data-ded-delay="2" data-category="odoo web">
                    <div class="ded-card overflow-hidden h-100">
                        <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#E07B1A33,#F59E0B22);display:flex;align-items:center;justify-content:center;font-size:4rem;">🛒</div>
                        <div class="p-4">
                            <div class="d-flex gap-2 mb-2">
                                <span style="background:rgba(224,123,26,.15);color:#FCD34D;border:1px solid rgba(224,123,26,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">Odoo</span>
                                <span style="background:rgba(224,123,26,.15);color:#FCD34D;border:1px solid rgba(224,123,26,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">E-Commerce</span>
                            </div>
                            <h5 class="text-white mb-2">E-Commerce Odoo Multilingua</h5>
                            <p style="color:rgba(255,255,255,.55);font-size:.9rem;line-height:1.6;">
                                Negozio online completo su Odoo con catalogo prodotti,
                                pagamenti integrati e gestione magazzino automatica.
                            </p>
                        </div>
                    </div>
                </div>
                <!-- Project 6: AI Training -->
                <div class="col-md-6 col-lg-4" data-ded-reveal="up" data-ded-delay="3" data-category="ai">
                    <div class="ded-card overflow-hidden h-100">
                        <div style="aspect-ratio:16/9;background:linear-gradient(135deg,#0A0F1E,#2563EB44);display:flex;align-items:center;justify-content:center;font-size:4rem;">🎓</div>
                        <div class="p-4">
                            <div class="d-flex gap-2 mb-2">
                                <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.2rem .75rem;font-size:.7rem;font-weight:600;">AI Training</span>
                            </div>
                            <h5 class="text-white mb-2">AI Training Aziendale</h5>
                            <p style="color:rgba(255,255,255,.55);font-size:.9rem;line-height:1.6;">
                                Programma di formazione AI per team aziendali.
                                Strumenti, best practice e governance dell'intelligenza artificiale.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5" data-ded-reveal="up">
                <a href="/contact" class="btn btn-primary btn-lg btn-magnetic">
                    Raccontaci il tuo progetto <i class="fa fa-arrow-right ms-2"/>
                </a>
            </div>
        </div>
    </section>

</div>
</t>
    </field>
</record>

</odoo>
