<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="s_ded_team" model="ir.ui.view">
    <field name="name">DED Team Section</field>
    <field name="type">qweb</field>
    <field name="key">theme_ded_partners.s_ded_team</field>
    <field name="arch" type="xml">
        <section class="s_ded_team ded-section ded-section-dark oe_structure"
                 data-snippet="s_ded_team" data-name="DED Team">
            <div class="container">
                <div class="text-center mb-5">
                    <span class="section-label">Il Team</span>
                    <h2 class="text-white">I nostri <span class="text-gradient">esperti</span></h2>
                </div>
                <div class="row g-4 justify-content-center">
                    <div class="col-md-6 col-lg-4">
                        <div class="ded-card p-4 text-center">
                            <div style="width:80px;height:80px;background:linear-gradient(135deg,var(--ded-blue),var(--ded-orange));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 1rem;">👨‍💻</div>
                            <h5 class="text-white mb-1">Membro del Team</h5>
                            <p style="color:var(--ded-orange);font-size:.875rem;margin-bottom:.75rem;">CEO &amp; Software Architect</p>
                            <p style="color:rgba(255,255,255,.5);font-size:.875rem;">Expert in AI, Python, Odoo</p>
                            <div class="d-flex gap-2 justify-content-center mt-3">
                                <a href="#" class="social-link"><i class="fa fa-linkedin"/></a>
                                <a href="#" class="social-link"><i class="fa fa-github"/></a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <div class="ded-card p-4 text-center">
                            <div style="width:80px;height:80px;background:linear-gradient(135deg,var(--ded-orange),var(--ded-blue));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 1rem;">👩‍💻</div>
                            <h5 class="text-white mb-1">Membro del Team</h5>
                            <p style="color:var(--ded-orange);font-size:.875rem;margin-bottom:.75rem;">CTO &amp; AI Engineer</p>
                            <p style="color:rgba(255,255,255,.5);font-size:.875rem;">Expert in Machine Learning, React</p>
                            <div class="d-flex gap-2 justify-content-center mt-3">
                                <a href="#" class="social-link"><i class="fa fa-linkedin"/></a>
                                <a href="#" class="social-link"><i class="fa fa-github"/></a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </field>
</record>

</odoo>
