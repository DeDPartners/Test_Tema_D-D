<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="s_ded_about" model="ir.ui.view">
    <field name="name">DED About Section</field>
    <field name="type">qweb</field>
    <field name="key">theme_ded_partners.s_ded_about</field>
    <field name="arch" type="xml">
        <section class="s_ded_about ded-section ded-section-glass oe_structure"
                 data-snippet="s_ded_about" data-name="DED Chi Siamo">
            <div class="container">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6">
                        <span class="section-label">Chi Siamo</span>
                        <h2 class="text-white mb-4">Innoviamo con <span class="text-gradient">passione</span></h2>
                        <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:2rem;">
                            Dal 2023 sviluppiamo soluzioni custom per soddisfare le esigenze uniche
                            dei nostri clienti pubblici e privati, leverando Python, React e Node.js.
                        </p>
                        <a href="/about" class="btn btn-primary">Scopri il team</a>
                    </div>
                    <div class="col-lg-6">
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="ded-card p-4 text-center">
                                    <div style="font-size:2rem;margin-bottom:.5rem;">🎯</div>
                                    <h6 class="text-white">Metodo</h6>
                                    <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Approccio strutturato e data-driven</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="ded-card p-4 text-center">
                                    <div style="font-size:2rem;margin-bottom:.5rem;">🚀</div>
                                    <h6 class="text-white">Velocità</h6>
                                    <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Delivery rapido con metodologie agili</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="ded-card p-4 text-center">
                                    <div style="font-size:2rem;margin-bottom:.5rem;">🛡️</div>
                                    <h6 class="text-white">Sicurezza</h6>
                                    <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">ISO 27001 certificato</p>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="ded-card p-4 text-center">
                                    <div style="font-size:2rem;margin-bottom:.5rem;">🤝</div>
                                    <h6 class="text-white">Supporto</h6>
                                    <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Assistenza continua post-lancio</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </field>
</record>

</odoo>
