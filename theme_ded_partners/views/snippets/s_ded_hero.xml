<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="s_ded_hero" model="ir.ui.view">
    <field name="name">DED Hero Section</field>
    <field name="type">qweb</field>
    <field name="key">theme_ded_partners.s_ded_hero</field>
    <field name="arch" type="xml">
        <section class="s_ded_hero ded-hero oe_structure" style="min-height:100vh;"
                 data-snippet="s_ded_hero" data-name="DED Hero">
            <canvas class="particle-canvas" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"/>
            <div class="container" style="position:relative;z-index:1;">
                <div class="row align-items-center min-vh-100">
                    <div class="col-lg-7">
                        <div class="ded-hero-badge">
                            <span class="dot"/>
                            <span>Odoo Partner · ISO 9001 · ISO 27001</span>
                        </div>
                        <h1 class="display-1 text-white mb-3">
                            Il tuo <span class="text-gradient">IT Partner</span><br/>di fiducia
                        </h1>
                        <p class="lead mb-5" style="color:rgba(255,255,255,.65);max-width:520px;">
                            Sviluppiamo soluzioni digitali custom per aziende private,
                            sanità e pubblica amministrazione.
                        </p>
                        <div class="d-flex flex-wrap gap-3">
                            <a href="/contact" class="btn btn-primary btn-lg">Inizia ora</a>
                            <a href="/services" class="btn btn-glass btn-lg">I nostri servizi</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </field>
</record>

</odoo>
