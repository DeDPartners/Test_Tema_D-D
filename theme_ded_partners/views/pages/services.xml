<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="ded_services_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners - Servizi</field>
    <field name="type">qweb</field>
    <field name="key">theme_ded_partners.services</field>
    <field name="arch" type="xml">
<t t-call="website.layout">
<div id="wrap" class="oe_structure oe_empty">

    <!-- Hero Services -->
    <section class="ded-hero" style="min-height:50vh;">
        <canvas id="ded-particle-canvas" class="particle-canvas" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"/>
        <div class="container" style="position:relative;z-index:1;padding-top:8rem;padding-bottom:5rem;">
            <div class="text-center">
                <span class="section-label">// services</span>
                <h1 class="display-1 text-white mb-3">I Nostri <span class="text-gradient">Servizi</span></h1>
                <p style="color:rgba(255,255,255,.6);font-size:1.2rem;max-width:600px;margin:0 auto;">
                    Soluzioni AI, software custom e consulenza Odoo per
                    aziende private, sanità e pubblica amministrazione.
                </p>
            </div>
        </div>
    </section>

    <!-- AI Agents -->
    <section class="ded-section ded-section-dark">
        <div class="container">
            <div class="row align-items-center g-5 mb-6">
                <div class="col-lg-6" data-ded-reveal="left">
                    <span class="section-label">AI Solutions</span>
                    <h2 class="text-white mb-4">Agenti AI <span class="text-gradient">Personalizzati</span></h2>
                    <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:1.5rem;">
                        Analizziamo i tuoi workflow, identifichiamo le opportunità ad alto impatto
                        e costruiamo agenti AI custom che si integrano con i tuoi strumenti esistenti.
                        Risultato: operazioni più veloci, meno errori, ROI misurabile.
                    </p>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <div class="ded-card p-3">
                                <i class="fa fa-calendar-check-o mb-2" style="color:var(--ded-orange);font-size:1.5rem;"/>
                                <h6 class="text-white mb-1">Calendario Booking AI</h6>
                                <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Gestione appuntamenti ottimizzata con AI</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="ded-card p-3">
                                <i class="fa fa-users mb-2" style="color:var(--ded-orange);font-size:1.5rem;"/>
                                <h6 class="text-white mb-1">Workforce AI</h6>
                                <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Pianificazione turni e ottimizzazione team</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="ded-card p-3">
                                <i class="fa fa-comments mb-2" style="color:var(--ded-orange);font-size:1.5rem;"/>
                                <h6 class="text-white mb-1">AI Reception</h6>
                                <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Front office intelligente 24/7</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="ded-card p-3">
                                <i class="fa fa-bar-chart mb-2" style="color:var(--ded-orange);font-size:1.5rem;"/>
                                <h6 class="text-white mb-1">Reporting AI</h6>
                                <p style="color:rgba(255,255,255,.5);font-size:.85rem;margin:0;">Report automatici per project &amp; staff</p>
                            </div>
                        </div>
                    </div>
                    <a href="/contact" class="btn btn-primary btn-magnetic">Richiedi una demo <i class="fa fa-arrow-right ms-2"/></a>
                </div>
                <div class="col-lg-6" data-ded-reveal="right">
                    <div class="ded-card p-5 text-center" style="background:linear-gradient(135deg,rgba(27,60,115,.5),rgba(37,99,235,.2));">
                        <div style="font-size:5rem;margin-bottom:1rem;">🤖</div>
                        <h4 class="text-white">Ready-to-Use AI Packages</h4>
                        <p style="color:rgba(255,255,255,.55);">Pacchetti AI pronti all'uso, configurabili in pochi giorni</p>
                        <div class="d-flex flex-column gap-2 mt-3">
                            <div class="d-flex align-items-center gap-2" style="background:rgba(255,255,255,.05);border-radius:8px;padding:.75rem 1rem;">
                                <i class="fa fa-check-circle" style="color:#4ADE80;"/>
                                <span style="color:rgba(255,255,255,.7);">Integrazione con sistemi esistenti</span>
                            </div>
                            <div class="d-flex align-items-center gap-2" style="background:rgba(255,255,255,.05);border-radius:8px;padding:.75rem 1rem;">
                                <i class="fa fa-check-circle" style="color:#4ADE80;"/>
                                <span style="color:rgba(255,255,255,.7);">Training del team incluso</span>
                            </div>
                            <div class="d-flex align-items-center gap-2" style="background:rgba(255,255,255,.05);border-radius:8px;padding:.75rem 1rem;">
                                <i class="fa fa-check-circle" style="color:#4ADE80;"/>
                                <span style="color:rgba(255,255,255,.7);">Supporto post-implementazione</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Separator -->
            <hr style="border-color:rgba(255,255,255,.08);margin:4rem 0;"/>

            <!-- Odoo Partner -->
            <div class="row align-items-center g-5 mb-6">
                <div class="col-lg-6 order-lg-2" data-ded-reveal="right">
                    <span class="section-label">Odoo Partner</span>
                    <h2 class="text-white mb-4">Odoo ERP <span class="text-gradient">Implementazione</span></h2>
                    <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:2rem;">
                        Siamo <strong style="color:#fff;">Odoo Partner ufficiali</strong>. Implementiamo, customizziamo
                        e supportiamo soluzioni Odoo per gestire CRM, vendite, magazzino,
                        contabilità, HR e molto altro in un unico ecosistema integrato.
                    </p>
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.375rem 1rem;font-size:.85rem;">CRM</span>
                        <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.375rem 1rem;font-size:.85rem;">Contabilità</span>
                        <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.375rem 1rem;font-size:.85rem;">E-Commerce</span>
                        <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.375rem 1rem;font-size:.85rem;">HR &amp; Payroll</span>
                        <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.375rem 1rem;font-size:.85rem;">Magazzino</span>
                        <span style="background:rgba(37,99,235,.15);color:#93C5FD;border:1px solid rgba(37,99,235,.3);border-radius:50px;padding:.375rem 1rem;font-size:.85rem;">Website Builder</span>
                    </div>
                    <a href="/contact" class="btn btn-primary btn-magnetic">Parla con un esperto Odoo</a>
                </div>
                <div class="col-lg-6 order-lg-1" data-ded-reveal="left">
                    <div class="ded-card p-5 text-center" style="background:linear-gradient(135deg,rgba(224,123,26,.15),rgba(245,158,11,.08));">
                        <div style="font-size:5rem;margin-bottom:1rem;">⚙️</div>
                        <div class="d-grid gap-3">
                            <div class="ded-card p-3 d-flex align-items-center gap-3">
                                <span style="font-size:1.5rem;">🔧</span>
                                <div class="text-start">
                                    <div class="fw-700 text-white" style="font-size:.9rem;">Odoo 17 · 18 · 19</div>
                                    <div style="color:rgba(255,255,255,.5);font-size:.8rem;">Versioni più recenti</div>
                                </div>
                            </div>
                            <div class="ded-card p-3 d-flex align-items-center gap-3">
                                <span style="font-size:1.5rem;">☁️</span>
                                <div class="text-start">
                                    <div class="fw-700 text-white" style="font-size:.9rem;">Odoo SH Cloud</div>
                                    <div style="color:rgba(255,255,255,.5);font-size:.8rem;">Deployment su Odoo.sh</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Certifications -->
            <hr style="border-color:rgba(255,255,255,.08);margin:4rem 0;"/>
            <div class="text-center mb-5" data-ded-reveal="up">
                <span class="section-label">Certificazioni</span>
                <h2 class="text-white">Qualita <span class="text-gradient">certificata</span></h2>
            </div>
            <div class="row g-4">
                <div class="col-md-6 col-lg-3" data-ded-reveal="up" data-ded-delay="1">
                    <div class="ded-card p-4 text-center h-100">
                        <div style="font-size:2.5rem;margin-bottom:1rem;">🏆</div>
                        <h5 class="text-white">ISO 9001:2015</h5>
                        <p style="color:rgba(255,255,255,.5);font-size:.875rem;line-height:1.6;">
                            Sistema di Gestione della Qualita. Garanzia di processi standardizzati e miglioramento continuo.
                        </p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3" data-ded-reveal="up" data-ded-delay="2">
                    <div class="ded-card p-4 text-center h-100">
                        <div style="font-size:2.5rem;margin-bottom:1rem;">🔒</div>
                        <h5 class="text-white">ISO 27001:2022</h5>
                        <p style="color:rgba(255,255,255,.5);font-size:.875rem;line-height:1.6;">
                            Information Security Management. Protezione avanzata dei dati sensibili.
                        </p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3" data-ded-reveal="up" data-ded-delay="3">
                    <div class="ded-card p-4 text-center h-100">
                        <div style="font-size:2.5rem;margin-bottom:1rem;">☁️</div>
                        <h5 class="text-white">ISO 27018:2019</h5>
                        <p style="color:rgba(255,255,255,.5);font-size:.875rem;line-height:1.6;">
                            Cloud Privacy. Protezione dei dati personali nei servizi cloud.
                        </p>
                    </div>
                </div>
                <div class="col-md-6 col-lg-3" data-ded-reveal="up" data-ded-delay="4">
                    <div class="ded-card p-4 text-center h-100">
                        <div style="font-size:2.5rem;margin-bottom:1rem;">🛡️</div>
                        <h5 class="text-white">ISO 27017:2015</h5>
                        <p style="color:rgba(255,255,255,.5);font-size:.875rem;line-height:1.6;">
                            Cloud Security. Controlli di sicurezza per i servizi cloud.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="ded-section">
        <div class="container">
            <div class="ded-cta text-center" data-ded-reveal="up">
                <h2 class="text-white mb-3">Pronto a modernizzare la tua operatività con l'AI?</h2>
                <p class="mb-4" style="color:rgba(255,255,255,.6);">Contattaci per una consulenza gratuita. <br/>Valuteremo le tue esigenze e proporremo la soluzione giusta.</p>
                <a href="/contact" class="btn btn-primary btn-lg btn-magnetic">
                    <i class="fa fa-envelope me-2"/>info@dedpartners.com
                </a>
            </div>
        </div>
    </section>

</div>
</t>
    </field>
</record>

<record id="ded_services_page" model="website.page">
    <field name="name">Servizi</field>
    <field name="url">/services</field>
    <field name="website_published">True</field>
    <field name="view_id" ref="ded_services_view"/>
</record>

</odoo>
