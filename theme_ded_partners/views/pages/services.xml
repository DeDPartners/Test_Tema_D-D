<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="ded_services_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners Servizi</field>
    <field name="key">theme_ded_partners.ded_services_view</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
<t t-name="theme_ded_partners.ded_services_view">
<t t-call="website.layout">
  <t t-set="pageName" t-value="'services'"/>
  <div id="wrap" class="ded-page-services">

    <!-- PAGE HERO -->
    <section class="ded-page-hero">
      <div class="ded-hero-bg"></div>
      <div class="ded-wrap">
        <span class="ded-eyebrow ded-reveal">Cosa facciamo</span>
        <h1 class="ded-reveal">Servizi <em>su misura,</em><br/>risultati misurabili.</h1>
        <p class="ded-page-hero-sub ded-reveal">Combiniamo strategia, design e ingegneria del software per costruire prodotti digitali che funzionano nel mondo reale. Nessun template, nessuna soluzione generica.</p>
      </div>
    </section>

    <!-- SERVICES BENTO -->
    <section style="padding:80px 0 120px">
      <div class="ded-wrap">
        <div class="ded-services">
          <article class="ded-card ded-c-1 ded-reveal">
            <div class="ded-ai-orb"></div>
            <div class="ded-ai-ring"></div>
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="3"/><path d="M12 1v6m0 10v6M4.22 4.22l4.24 4.24m7.08 7.08l4.24 4.24M1 12h6m10 0h6M4.22 19.78l4.24-4.24m7.08-7.08l4.24-4.24"/></svg>
            </div>
            <h3>AI Agents personalizzati</h3>
            <p>Installiamo, addestriamo e integriamo agenti AI sui tuoi processi: knowledge base, supporto clienti, automazione interna. Modulari, sicuri, sulla tua infrastruttura.</p>
          </article>
          <article class="ded-card ded-c-2 ded-reveal">
            <span class="ded-odoo-badge">● Odoo Official Partner</span>
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 7l9-4 9 4-9 4-9-4zm0 5l9 4 9-4M3 17l9 4 9-4"/></svg>
            </div>
            <h3>Implementazione Odoo</h3>
            <p>ERP, CRM, e-commerce e moduli custom Odoo. Migrazioni complete, personalizzazioni e supporto continuativo da partner certificato.</p>
          </article>
          <article class="ded-card ded-c-3 ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 18l6-6-6-6M8 6l-6 6 6 6"/></svg>
            </div>
            <h3>Sviluppo software custom</h3>
            <p>Python, React, Node.js. Backend solidi, frontend reattivi, architetture pensate per scalare. Dal prototipo al prodotto in produzione.</p>
          </article>
          <article class="ded-card ded-c-4 ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="5" y="2" width="14" height="20" rx="2.5"/><path d="M11 18h2"/></svg>
            </div>
            <h3>Web &amp; Mobile Apps</h3>
            <p>App native e web app performanti. Una codebase, esperienza coerente ovunque. iOS, Android, PWA.</p>
          </article>
          <article class="ded-card ded-c-5 ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 3v18h18M7 14l3-3 4 4 5-7"/></svg>
            </div>
            <h3>Dashboard &amp; Data Analysis</h3>
            <p>Trasformiamo dati grezzi in decisioni: dashboard chiare, KPI vivi, insight actionable. BI, real-time analytics, reporting automatico.</p>
          </article>
          <article class="ded-card ded-c-6 ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 2l8 4v6c0 5-3.5 9-8 10-4.5-1-8-5-8-10V6l8-4z"/></svg>
            </div>
            <h3>Sicurezza &amp; Compliance</h3>
            <p>Standard ISO, GDPR-ready, hardening dell'infrastruttura. Penetration testing, vulnerability assessment, audit di sicurezza.</p>
          </article>
          <article class="ded-card ded-c-7 ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>
            </div>
            <h3>Supporto continuativo</h3>
            <p>Non scompariamo dopo la consegna: SLA chiari, monitoraggio attivo, evoluzioni costanti. DevOps, CI/CD, infrastructure management.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- AI SECTION -->
    <section class="ded-ai-section">
      <div class="ded-ai-wrap ded-wrap">
        <span class="ded-eyebrow ded-reveal">Intelligenza artificiale</span>
        <h2 class="ded-reveal">Agenti AI che lavorano<br/><span class="ded-grad">davvero per te.</span></h2>
        <p class="ded-reveal">Non chatbot finti: agenti integrati nei tuoi flussi, addestrati sui tuoi dati, in esecuzione dove serve — cloud, on-premise, ibrido.</p>
        <div class="ded-ai-grid">
          <div class="ded-ai-feat ded-reveal">
            <div class="ded-num">01</div>
            <h4>Discovery &amp; Use Case</h4>
            <p>Mappiamo i tuoi processi e identifichiamo dove un agente AI porta valore reale (e dove no).</p>
          </div>
          <div class="ded-ai-feat ded-reveal">
            <div class="ded-num">02</div>
            <h4>Build &amp; Train</h4>
            <p>Sviluppiamo l'agente, lo connettiamo alle tue fonti dati e lo addestriamo sul dominio.</p>
          </div>
          <div class="ded-ai-feat ded-reveal">
            <div class="ded-num">03</div>
            <h4>Deploy &amp; Evolve</h4>
            <p>Rilascio sicuro, monitoraggio continuo, evoluzione del modello sui feedback reali.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ODOO PARTNER DETAIL -->
    <section style="padding:60px 0 120px">
      <div class="ded-wrap">
        <div class="ded-odoo ded-reveal">
          <div class="ded-odoo-inner">
            <div>
              <span class="ded-badge">★ Official Odoo Partner</span>
              <h3>Tutto il tuo business, <em>in un'unica piattaforma.</em></h3>
              <p>Come partner ufficiali Odoo, integriamo, personalizziamo e supportiamo l'intero ecosistema Odoo — dalla contabilità alle vendite, dal magazzino al CRM. Anche il tuo sito può essere agganciato a Odoo per gestione lead, marketing e analytics in tempo reale.</p>
              <ul class="ded-features">
                <li>Implementazione e configurazione completa</li>
                <li>Moduli custom su misura del tuo business</li>
                <li>Migrazione dati da sistemi legacy</li>
                <li>Formazione team e supporto continuativo</li>
              </ul>
            </div>
            <div class="ded-odoo-visual">
              <div class="ded-module"><span class="ded-dot"></span>CRM &amp; Sales</div>
              <div class="ded-module"><span class="ded-dot"></span>Accounting</div>
              <div class="ded-module"><span class="ded-dot"></span>Inventory</div>
              <div class="ded-module"><span class="ded-dot"></span>Website &amp; eCommerce</div>
              <div class="ded-module"><span class="ded-dot"></span>Marketing Automation</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- TECH MARQUEE -->
    <div class="ded-marquee">
      <div class="ded-marquee-track">
        <span>Python</span><span>React</span><span>Node.js</span><span>Odoo</span><span>PostgreSQL</span>
        <span>TensorFlow</span><span>Docker</span><span>Kubernetes</span><span>AWS</span><span>Azure</span>
        <span>Python</span><span>React</span><span>Node.js</span><span>Odoo</span><span>PostgreSQL</span>
        <span>TensorFlow</span><span>Docker</span><span>Kubernetes</span><span>AWS</span><span>Azure</span>
      </div>
    </div>

    <!-- CTA -->
    <section class="ded-cta">
      <span class="ded-eyebrow ded-reveal">Inizia ora</span>
      <h2 class="ded-reveal">Qual è la tua<br/><em>sfida digitale?</em></h2>
      <p class="ded-cta-sub ded-reveal">Raccontacela. In 24 ore ti diciamo come possiamo aiutarti — con una prima analisi gratuita.</p>
      <div class="ded-cta-actions ded-reveal">
        <a href="mailto:info@dedpartners.com" class="ded-btn ded-btn-primary">
          <span>Scrivici una mail</span>
          <svg class="ded-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
        <a href="/contatti" class="ded-btn ded-btn-ghost"><span>Vai ai contatti</span></a>
      </div>
    </section>

  </div>
</t>
</t>
    </field>
</record>

<record id="ded_services_page" model="website.page">
    <field name="name">Servizi</field>
    <field name="website_published">True</field>
    <field name="url">/servizi</field>
    <field name="view_id" ref="ded_services_view"/>
</record>

</odoo>
