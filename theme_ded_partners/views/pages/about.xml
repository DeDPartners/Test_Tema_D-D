<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="ded_about_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners Chi Siamo</field>
    <field name="key">theme_ded_partners.ded_about_view</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
<t t-name="theme_ded_partners.ded_about_view">
<t t-call="website.layout">
  <t t-set="pageName" t-value="'about'"/>
  <div id="wrap" class="ded-page-about">

    <!-- PAGE HERO -->
    <section class="ded-page-hero">
      <div class="ded-hero-bg"></div>
      <div class="ded-wrap">
        <span class="ded-eyebrow ded-reveal">Chi siamo</span>
        <h1 class="ded-reveal">Engineering <em>tomorrow's</em><br/>software.</h1>
        <p class="ded-page-hero-sub ded-reveal">D&amp;D Partners S.r.l. è una società di consulenza IT con sede a Padova, specializzata in sviluppo software custom, AI agents e Odoo. Fondata nel 2023 da un team di ingegneri con esperienza nel settore pubblico, healthcare e privato.</p>
      </div>
    </section>

    <!-- MISSION -->
    <section style="padding:100px 0">
      <div class="ded-wrap">
        <div class="ded-about-grid ded-reveal">
          <div>
            <span class="ded-eyebrow">La nostra missione</span>
            <h2>Tecnologia che <em>risolve problemi veri.</em></h2>
            <p style="color:var(--fg-dim);margin-top:24px;font-size:17px;line-height:1.65">Non costruiamo software per il gusto della tecnologia. Lo facciamo perché crediamo che ogni organizzazione — pubblica o privata — meriti strumenti digitali che funzionano davvero, scalano nel tempo e non creano dipendenza da vendor opachi.</p>
            <p style="color:var(--fg-dim);margin-top:16px;font-size:17px;line-height:1.65">Il nostro approccio: ascolto profondo, architettura solida, consegna veloce. Senza fumo.</p>
          </div>
          <div class="ded-about-stats">
            <div class="ded-stat-card">
              <div class="ded-stat-num">2023</div>
              <div class="ded-stat-lbl">Anno di fondazione</div>
            </div>
            <div class="ded-stat-card">
              <div class="ded-stat-num">50+</div>
              <div class="ded-stat-lbl">Progetti consegnati</div>
            </div>
            <div class="ded-stat-card">
              <div class="ded-stat-num">12+</div>
              <div class="ded-stat-lbl">Esperti in team</div>
            </div>
            <div class="ded-stat-card">
              <div class="ded-stat-num">ISO</div>
              <div class="ded-stat-lbl">9001 &amp; 27001 certified</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- VALUES -->
    <section style="padding:0 0 100px">
      <div class="ded-wrap">
        <div class="ded-section-head ded-reveal">
          <span class="ded-eyebrow">I nostri valori</span>
          <h2>Cosa ci guida <em>ogni giorno.</em></h2>
        </div>
        <div class="ded-values-grid">
          <div class="ded-card ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <h3>Qualità certificata</h3>
            <p>ISO 9001 e ISO 27001. Non badge decorativi: processi reali, audit continuativi, qualità misurabile.</p>
          </div>
          <div class="ded-card ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h3>Persone prima</h3>
            <p>Lavoriamo con persone, non con ticket. Costruiamo relazioni durature con i clienti, non transazioni.</p>
          </div>
          <div class="ded-card ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </div>
            <h3>Velocità con sostanza</h3>
            <p>Sprint veloci, nessuna scorciatoia. Il codice che consegniamo è quello che manteniamo.</p>
          </div>
          <div class="ded-card ded-reveal">
            <div class="ded-icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            </div>
            <h3>Partnership continua</h3>
            <p>Il progetto non finisce al go-live. Siamo al tuo fianco mentre il prodotto cresce e cambia.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CERTIFICATIONS -->
    <section style="padding:60px 0 120px;border-top:1px solid var(--line)">
      <div class="ded-wrap">
        <div class="ded-section-head ded-reveal">
          <span class="ded-eyebrow">Certificazioni</span>
          <h2>Conformità e <em>sicurezza.</em></h2>
        </div>
        <div class="ded-process-grid">
          <div class="ded-step ded-reveal">
            <div class="ded-step-n" style="font-size:36px">ISO</div>
            <h4>ISO 9001:2015</h4>
            <p>Sistema di gestione della qualità certificato. Processi standardizzati, customer satisfaction misurabile.</p>
          </div>
          <div class="ded-step ded-reveal">
            <div class="ded-step-n" style="font-size:36px">ISO</div>
            <h4>ISO 27001:2022</h4>
            <p>Sicurezza delle informazioni certificata. Gestione del rischio, protezione dei dati, GDPR-ready.</p>
          </div>
          <div class="ded-step ded-reveal">
            <div class="ded-step-n" style="font-size:28px">ODP</div>
            <h4>Odoo Official Partner</h4>
            <p>Partner ufficiale Odoo. Implementazioni certificate, team formato direttamente da Odoo S.A.</p>
          </div>
          <div class="ded-step ded-reveal">
            <div class="ded-step-n" style="font-size:28px">EU</div>
            <h4>GDPR Compliant</h4>
            <p>Conformità al Regolamento Europeo sulla protezione dei dati in tutti i prodotti e processi.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="ded-cta">
      <span class="ded-eyebrow ded-reveal">Lavoriamo insieme</span>
      <h2 class="ded-reveal">Vuoi conoscerci<br/><em>di persona?</em></h2>
      <p class="ded-cta-sub ded-reveal">Vieni a trovarci a Padova o chiamaci: siamo persone vere, con passione vera per il software.</p>
      <div class="ded-cta-actions ded-reveal">
        <a href="/contatti" class="ded-btn ded-btn-primary">
          <span>Contattaci</span>
          <svg class="ded-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
        <a href="/servizi" class="ded-btn ded-btn-ghost"><span>Scopri i nostri servizi</span></a>
      </div>
    </section>

  </div>
</t>
</t>
    </field>
</record>

<record id="ded_about_page" model="website.page">
    <field name="name">Chi Siamo</field>
    <field name="website_published">True</field>
    <field name="url">/chi-siamo</field>
    <field name="view_id" ref="ded_about_view"/>
</record>

</odoo>
