<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="ded_portfolio_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners Portfolio</field>
    <field name="key">theme_ded_partners.ded_portfolio_view</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
<t t-name="theme_ded_partners.ded_portfolio_view">
<t t-call="website.layout">
  <t t-set="pageName" t-value="'portfolio'"/>
  <div id="wrap" class="ded-page-portfolio">

    <!-- PAGE HERO -->
    <section class="ded-page-hero">
      <div class="ded-hero-bg"></div>
      <div class="ded-wrap">
        <span class="ded-eyebrow ded-reveal">I nostri lavori</span>
        <h1 class="ded-reveal">Progetti che <em>fanno</em><br/>la differenza.</h1>
        <p class="ded-page-hero-sub ded-reveal">Ogni progetto è una storia di sfida, collaborazione e risultati concreti. Dalla Pubblica Amministrazione all'healthcare, dall'industria alle startup.</p>
      </div>
    </section>

    <!-- PORTFOLIO GRID -->
    <section style="padding:80px 0 120px">
      <div class="ded-wrap">
        <div class="ded-portfolio-grid">

          <article class="ded-port-card ded-port-featured ded-reveal">
            <div class="ded-port-tag">Pubblica Amministrazione</div>
            <h3>Portale Servizi Digitali Comune</h3>
            <p>Sviluppo portale web integrato con SPID, PagoPA e ANPR per comune capoluogo. Accesso ai servizi digitali per oltre 80.000 cittadini. Stack: Python, React, PostgreSQL.</p>
            <div class="ded-port-meta">
              <span>React</span><span>Python</span><span>SPID</span><span>PagoPA</span>
            </div>
          </article>

          <article class="ded-port-card ded-reveal">
            <div class="ded-port-tag">Healthcare</div>
            <h3>AI per Diagnostica Clinica</h3>
            <p>Agente AI per supporto alla diagnosi radiologica. Integrazione con PACS, analisi immagini in real-time. GDPR-compliant, certificato MDR.</p>
            <div class="ded-port-meta">
              <span>TensorFlow</span><span>Python</span><span>GDPR</span>
            </div>
          </article>

          <article class="ded-port-card ded-reveal">
            <div class="ded-port-tag">Odoo ERP</div>
            <h3>Implementazione Odoo per Industria</h3>
            <p>Migrazione completa da SAP a Odoo 17 per azienda manifatturiera. CRM, magazzino, produzione, contabilità. 0 downtime in produzione.</p>
            <div class="ded-port-meta">
              <span>Odoo 17</span><span>Migrazione</span><span>Manifattura</span>
            </div>
          </article>

          <article class="ded-port-card ded-reveal">
            <div class="ded-port-tag">AI Agents</div>
            <h3>Customer Support Agent Enterprise</h3>
            <p>Agente AI multilingue per gestione supporto clienti. Knowledge base proprietaria, escalation automatica, integrazione CRM. -60% ticket manuali.</p>
            <div class="ded-port-meta">
              <span>LLM</span><span>RAG</span><span>Odoo CRM</span>
            </div>
          </article>

          <article class="ded-port-card ded-reveal">
            <div class="ded-port-tag">Dashboard &amp; BI</div>
            <h3>Dashboard Operativa Real-Time</h3>
            <p>Sistema di business intelligence per catena logistica. 50+ KPI in tempo reale, alert automatici, reporting multi-sede. 40% riduzione tempi decisionali.</p>
            <div class="ded-port-meta">
              <span>React</span><span>PostgreSQL</span><span>Metabase</span>
            </div>
          </article>

          <article class="ded-port-card ded-reveal">
            <div class="ded-port-tag">Mobile App</div>
            <h3>App Gestione Interventi Tecnici</h3>
            <p>App mobile cross-platform per team di tecnici sul campo. Geolocalizzazione, firma digitale, sincronizzazione offline. 200+ utenti attivi.</p>
            <div class="ded-port-meta">
              <span>React Native</span><span>Node.js</span><span>PWA</span>
            </div>
          </article>

        </div>
      </div>
    </section>

    <!-- SECTORS -->
    <section style="padding:0 0 80px">
      <div class="ded-wrap" style="padding-bottom:80px">
        <div class="ded-section-head ded-reveal">
          <span class="ded-eyebrow">Settori</span>
          <h2>Dove operiamo <em>con più profondità.</em></h2>
        </div>
      </div>
      <div class="ded-sectors">
        <article class="ded-sector ded-s-pa ded-reveal">
          <span class="ded-tag"><span class="ded-pip"></span>01 — Pubblica Amministrazione</span>
          <h3>Digitalizzazione che funziona davvero per il cittadino.</h3>
          <p>Portali, gestionali, integrazioni con PagoPA, SPID, ANPR. Conformi, accessibili, performanti.</p>
          <a href="/servizi" class="ded-more">Scopri di più →</a>
        </article>
        <article class="ded-sector ded-s-hc ded-reveal">
          <span class="ded-tag"><span class="ded-pip"></span>02 — Healthcare</span>
          <h3>Innovazione clinica supportata da AI affidabile.</h3>
          <p>Software per cliniche, R&amp;D in AI medicale, gestione dati pazienti GDPR-compliant.</p>
          <a href="/servizi" class="ded-more">Scopri di più →</a>
        </article>
        <article class="ded-sector ded-s-pr ded-reveal">
          <span class="ded-tag"><span class="ded-pip"></span>03 — Imprese &amp; Industria</span>
          <h3>Software che fa correre il tuo business.</h3>
          <p>ERP, CRM, automazioni, dashboard. Strumenti pensati per chi non ha tempo da perdere.</p>
          <a href="/servizi" class="ded-more">Scopri di più →</a>
        </article>
      </div>
    </section>

    <!-- CTA -->
    <section class="ded-cta">
      <span class="ded-eyebrow ded-reveal">Il prossimo progetto</span>
      <h2 class="ded-reveal">Il tuo caso<br/><em>diventa il nostro.</em></h2>
      <p class="ded-cta-sub ded-reveal">Raccontaci la tua sfida. Ti mostriamo come l'abbiamo affrontata in contesti simili e cosa potremmo costruire insieme.</p>
      <div class="ded-cta-actions ded-reveal">
        <a href="mailto:info@dedpartners.com" class="ded-btn ded-btn-primary">
          <span>Parliamo del tuo progetto</span>
          <svg class="ded-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
        <a href="/contatti" class="ded-btn ded-btn-ghost"><span>Tutti i contatti</span></a>
      </div>
    </section>

  </div>
</t>
</t>
    </field>
</record>

<record id="ded_portfolio_page" model="website.page">
    <field name="name">Portfolio</field>
    <field name="website_published">True</field>
    <field name="url">/portfolio</field>
    <field name="view_id" ref="ded_portfolio_view"/>
</record>

</odoo>
