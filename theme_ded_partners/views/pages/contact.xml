<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="ded_contact_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners Contatti</field>
    <field name="key">theme_ded_partners.ded_contact_view</field>
    <field name="type">qweb</field>
    <field name="arch" type="xml">
<t t-name="theme_ded_partners.ded_contact_view">
<t t-call="website.layout">
  <t t-set="pageName" t-value="'contact'"/>
  <div id="wrap" class="ded-page-contact">

    <!-- PAGE HERO / CTA -->
    <section class="ded-cta" style="border-top:none;padding-top:180px">
      <span class="ded-eyebrow ded-reveal">Get in touch</span>
      <h1 class="ded-reveal" style="font-size:clamp(44px,7vw,108px);font-weight:500;line-height:1;letter-spacing:-.045em;max-width:14ch;margin:24px auto 0">
        Hai un'idea?<br/><em style="font-family:'Instrument Serif',serif;font-style:italic;color:var(--fg-dim);font-weight:400">Trasformiamola in prodotto.</em>
      </h1>
      <p class="ded-cta-sub ded-reveal">Raccontaci dove vuoi andare. Ti rispondiamo entro 24 ore con una prima analisi gratuita.</p>
      <div class="ded-cta-actions ded-reveal">
        <a href="mailto:info@dedpartners.com" class="ded-btn ded-btn-primary">
          <span>Scrivici una mail</span>
          <svg class="ded-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M7 7h10v10"/></svg>
        </a>
        <a href="tel:+390490962657" class="ded-btn ded-btn-ghost"><span>Chiama il team</span></a>
      </div>

      <div class="ded-contact-meta ded-reveal">
        <div class="ded-item">
          <div class="ded-lbl">Email</div>
          <div class="ded-val">
            <a href="mailto:info@dedpartners.com">info@dedpartners.com</a>
            <a href="mailto:dedpartners@pec.it">dedpartners@pec.it</a>
          </div>
        </div>
        <div class="ded-item">
          <div class="ded-lbl">Telefono</div>
          <div class="ded-val">
            <a href="tel:+390490962657">+39 049 0962657</a>
            <a href="tel:+393802104571">+39 380 2104571</a>
          </div>
        </div>
        <div class="ded-item">
          <div class="ded-lbl">Dove siamo</div>
          <div class="ded-val">Via Guido Rossa 8<br/>35020 Padova, IT</div>
        </div>
      </div>
    </section>

    <!-- CONTACT INFO DETAILS -->
    <section style="padding:80px 0 120px;border-top:1px solid var(--line)">
      <div class="ded-wrap">
        <div class="ded-about-grid ded-reveal">
          <div>
            <span class="ded-eyebrow">Vieni a trovarci</span>
            <h2 style="margin-top:20px">D&amp;D Partners <em>S.r.l.</em></h2>
            <p style="color:var(--fg-dim);margin-top:24px;font-size:17px;line-height:1.65">
              Via Guido Rossa 8<br/>
              35020 Padova (PD), Italia<br/>
              P.IVA IT05355160283
            </p>
            <p style="color:var(--fg-dim);margin-top:20px;font-size:15px;line-height:1.65">
              <strong style="color:var(--fg)">Orari:</strong> Lun–Ven 9:00–18:00<br/>
              <strong style="color:var(--fg)">Email:</strong> <a href="mailto:info@dedpartners.com" style="color:var(--accent)">info@dedpartners.com</a><br/>
              <strong style="color:var(--fg)">PEC:</strong> <a href="mailto:dedpartners@pec.it" style="color:var(--accent)">dedpartners@pec.it</a><br/>
              <strong style="color:var(--fg)">Tel:</strong> <a href="tel:+390490962657" style="color:var(--accent)">+39 049 0962657</a>
            </p>
            <div style="margin-top:36px;display:flex;gap:12px;flex-wrap:wrap">
              <a href="https://www.linkedin.com/company/dedpartners/" target="_blank" class="ded-btn ded-btn-ghost" style="font-size:13px;padding:8px 18px">
                LinkedIn ↗
              </a>
              <a href="https://github.com/DeDPartners" target="_blank" class="ded-btn ded-btn-ghost" style="font-size:13px;padding:8px 18px">
                GitHub ↗
              </a>
            </div>
          </div>
          <div class="ded-about-stats">
            <div class="ded-stat-card">
              <div class="ded-stat-num" style="font-size:28px">ISO</div>
              <div class="ded-stat-lbl">9001 &amp; 27001</div>
            </div>
            <div class="ded-stat-card">
              <div class="ded-stat-num">ODP</div>
              <div class="ded-stat-lbl">Odoo Official Partner</div>
            </div>
            <div class="ded-stat-card">
              <div class="ded-stat-num">EU</div>
              <div class="ded-stat-lbl">GDPR Compliant</div>
            </div>
            <div class="ded-stat-card">
              <div class="ded-stat-num">&lt;24h</div>
              <div class="ded-stat-lbl">Tempo di risposta</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- MAP -->
    <section style="padding:0 0 0;border-top:1px solid var(--line)">
      <div class="ded-wrap" style="padding-top:80px;padding-bottom:80px">
        <div class="ded-section-head ded-reveal">
          <span class="ded-eyebrow">Dove siamo</span>
          <h2>Vieni a <em>trovarci.</em></h2>
        </div>
        <div class="ded-reveal" style="border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--line);position:relative">
          <iframe
            title="D&amp;D Partners — Via Guido Rossa 8, Padova"
            src="https://www.openstreetmap.org/export/embed.html?bbox=11.8600%2C45.3930%2C11.9060%2C45.4230&amp;layer=mapnik&amp;marker=45.4080%2C11.8830"
            width="100%"
            height="440"
            frameborder="0"
            scrolling="no"
            style="display:block;filter:invert(92%) hue-rotate(188deg) saturate(0.85) brightness(0.88);border:none"
            allowfullscreen="allowfullscreen">
          </iframe>
          <div style="position:absolute;bottom:20px;right:20px;z-index:10">
            <a href="https://www.openstreetmap.org/?mlat=45.4080&amp;mlon=11.8830#map=15/45.4080/11.8830"
               target="_blank" rel="noopener"
               class="ded-btn ded-btn-ghost"
               style="font-size:12px;padding:8px 16px;background:rgba(0,0,0,.8);backdrop-filter:blur(8px)">
              Apri in Maps ↗
            </a>
          </div>
        </div>
        <p style="margin-top:16px;font-size:13px;color:var(--fg-mute);text-align:center">
          Via Guido Rossa 8, 35020 Padova (PD) — Lun–Ven 9:00–18:00
        </p>
      </div>
    </section>

    <!-- PROCESS QUICK VIEW -->
    <section style="padding:0 0 120px;border-top:1px solid var(--line)">
      <div class="ded-wrap" style="padding-top:80px">
        <div class="ded-section-head ded-reveal">
          <span class="ded-eyebrow">Come iniziamo</span>
          <h2>Dal primo contatto <em>al primo sprint.</em></h2>
        </div>
        <div class="ded-process-grid">
          <div class="ded-step ded-reveal">
            <div class="ded-step-n">01</div>
            <h4>Ci scrivi</h4>
            <p>Manda una mail o chiamaci. Non serve un brief completo: basta raccontarci la sfida.</p>
          </div>
          <div class="ded-step ded-reveal">
            <div class="ded-step-n">02</div>
            <h4>Prima call</h4>
            <p>Videocall gratuita di 45 minuti per capire il contesto e valutare insieme l'approccio migliore.</p>
          </div>
          <div class="ded-step ded-reveal">
            <div class="ded-step-n">03</div>
            <h4>Analisi gratuita</h4>
            <p>Entro 24 ore una prima analisi: scope, stima di massima, rischi identificati, raccomandazioni.</p>
          </div>
          <div class="ded-step ded-reveal">
            <div class="ded-step-n">04</div>
            <h4>Proposta formale</h4>
            <p>Se tutto quadra, proposta dettagliata con tempi, costi e piano di lavoro. Nessun impegno fino alla firma.</p>
          </div>
        </div>
      </div>
    </section>

  </div>
</t>
</t>
    </field>
</record>

<record id="ded_contact_page" model="website.page">
    <field name="name">Contatti</field>
    <field name="website_published">True</field>
    <field name="url">/contatti</field>
    <field name="view_id" ref="ded_contact_view"/>
</record>

</odoo>
