<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ================================================================
     HOME PAGE - D&D Partners
     Tech-forward, Apple-inspired, WOW effects
     ================================================================ -->

<record id="ded_home_view" model="ir.ui.view">
    <field name="name">D&amp;D Partners - Home</field>
    <field name="type">qweb</field>
    <field name="key">theme_ded_partners.home</field>
    <field name="arch" type="xml">
<t t-call="website.layout">
<div id="wrap" class="oe_structure oe_empty">

    <!-- ── HERO ─────────────────────────────────────── -->
    <section class="ded-hero ded-section" id="home-hero">
        <canvas id="ded-particle-canvas" class="particle-canvas" style="position:absolute;inset:0;width:100%;height:100%;z-index:0;pointer-events:none;"/>

        <!-- Floating orbs -->
        <div style="position:absolute;top:10%;left:5%;width:300px;height:300px;background:radial-gradient(circle,rgba(37,99,235,.2),transparent 70%);border-radius:50%;filter:blur(40px);animation:glow-pulse 8s infinite;z-index:0;pointer-events:none;"/>
        <div style="position:absolute;bottom:15%;right:8%;width:250px;height:250px;background:radial-gradient(circle,rgba(224,123,26,.15),transparent 70%);border-radius:50%;filter:blur(40px);animation:glow-pulse 10s infinite 2s;z-index:0;pointer-events:none;"/>

        <div class="container" style="position:relative;z-index:1;">
            <div class="row align-items-center min-vh-100">
                <div class="col-lg-7 col-xl-6 ded-hero-content">
                    <!-- Badge -->
                    <div class="ded-hero-badge" data-ded-reveal="left">
                        <span class="dot"/>
                        <span class="font-mono">Odoo Partner · ISO 9001 · ISO 27001</span>
                    </div>

                    <!-- Headline -->
                    <h1 class="display-1 text-white mb-3" data-ded-reveal="up" style="line-height:1.08;">
                        Soluzioni IT<br/>
                        <span class="text-gradient" data-typed="per il tuo Business|con AI Agents|per la PA|per la Sanita|con Odoo"/>
                        <span class="typed-cursor"/>
                    </h1>

                    <p class="lead mb-5" data-ded-reveal="up" data-ded-delay="2"
                       style="color:rgba(255,255,255,.65);font-size:1.2rem;max-width:520px;line-height:1.7;">
                        Sviluppiamo software custom, agenti AI e soluzioni Odoo per
                        aziende private, sanità e pubblica amministrazione.
                        Dal 2023, innoviamo il futuro digitale dei nostri clienti.
                    </p>

                    <div class="d-flex flex-wrap gap-3" data-ded-reveal="up" data-ded-delay="3">
                        <a href="/contact" class="btn btn-primary btn-lg btn-magnetic">
                            <i class="fa fa-rocket me-2"/>Inizia il tuo progetto
                        </a>
                        <a href="/services" class="btn btn-glass btn-lg btn-magnetic">
                            <i class="fa fa-play-circle me-2"/>I nostri servizi
                        </a>
                    </div>

                    <!-- Trust badges -->
                    <div class="d-flex flex-wrap gap-4 mt-5" data-ded-reveal="up" data-ded-delay="4">
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa fa-shield" style="color:var(--ded-orange);font-size:1.25rem;"/>
                            <span style="color:rgba(255,255,255,.55);font-size:.875rem;">ISO 9001:2015</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa fa-lock" style="color:var(--ded-orange);font-size:1.25rem;"/>
                            <span style="color:rgba(255,255,255,.55);font-size:.875rem;">ISO 27001:2022</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            <i class="fa fa-certificate" style="color:var(--ded-orange);font-size:1.25rem;"/>
                            <span style="color:rgba(255,255,255,.55);font-size:.875rem;">Odoo Partner</span>
                        </div>
                    </div>
                </div>

                <!-- Hero visual: bento card cluster -->
                <div class="col-lg-5 col-xl-6 d-none d-lg-flex justify-content-center" data-ded-reveal="right">
                    <div style="position:relative;width:100%;max-width:480px;">
                        <!-- Main card -->
                        <div class="ded-card p-4 mb-3" style="background:rgba(27,60,115,.4);">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <div style="width:40px;height:40px;background:var(--ded-gradient-accent);border-radius:10px;display:flex;align-items:center;justify-content:center;">
                                    <i class="fa fa-robot text-white"/>
                                </div>
                                <div>
                                    <div class="fw-700 text-white" style="font-size:.9rem;">AI Agent attivi</div>
                                    <div style="color:rgba(255,255,255,.5);font-size:.75rem;">Real-time processing</div>
                                </div>
                                <div class="ms-auto">
                                    <span style="background:rgba(34,197,94,.15);color:#4ADE80;border:1px solid rgba(34,197,94,.3);border-radius:50px;padding:.2rem .75rem;font-size:.75rem;font-weight:600;">LIVE</span>
                                </div>
                            </div>
                            <!-- Mini bar chart -->
                            <div class="d-flex align-items-end gap-1" style="height:60px;">
                                <div style="flex:1;background:var(--ded-blue);border-radius:4px 4px 0 0;height:40%;opacity:.6;"/>
                                <div style="flex:1;background:var(--ded-blue);border-radius:4px 4px 0 0;height:65%;opacity:.7;"/>
                                <div style="flex:1;background:var(--ded-orange);border-radius:4px 4px 0 0;height:80%;"/>
                                <div style="flex:1;background:var(--ded-blue);border-radius:4px 4px 0 0;height:55%;opacity:.7;"/>
                                <div style="flex:1;background:var(--ded-orange);border-radius:4px 4px 0 0;height:90%;"/>
                                <div style="flex:1;background:var(--ded-blue);border-radius:4px 4px 0 0;height:70%;opacity:.8;"/>
                                <div style="flex:1;background:var(--ded-blue);border-radius:4px 4px 0 0;height:100%;"/>
                            </div>
                        </div>
                        <!-- Small cards row -->
                        <div class="d-flex gap-3">
                            <div class="ded-card p-3 flex-fill text-center" style="background:rgba(224,123,26,.1);border-color:rgba(224,123,26,.2);">
                                <div class="fw-800 text-white" style="font-size:1.75rem;" data-count="98" data-count-suffix="%">0%</div>
                                <div style="font-size:.75rem;color:rgba(255,255,255,.5);">Clienti soddisfatti</div>
                            </div>
                            <div class="ded-card p-3 flex-fill text-center">
                                <div class="fw-800 text-white" style="font-size:1.75rem;" data-count="50" data-count-suffix="+">0+</div>
                                <div style="font-size:.75rem;color:rgba(255,255,255,.5);">Progetti completati</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div style="position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);z-index:1;text-align:center;">
            <a href="#services" style="color:rgba(255,255,255,.4);text-decoration:none;">
                <div style="font-size:.75rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.5rem;">Scroll</div>
                <div style="width:1px;height:40px;background:linear-gradient(180deg,rgba(255,255,255,.4),transparent);margin:0 auto;"/>
            </a>
        </div>
    </section>

    <!-- ── STATS BAR ──────────────────────────────────── -->
    <section class="ded-section" style="padding:3rem 0;background:var(--ded-bg-mid);border-top:1px solid rgba(255,255,255,.06);border-bottom:1px solid rgba(255,255,255,.06);">
        <div class="container">
            <div class="row ded-stats">
                <div class="col-6 col-md-3 ded-stat-item" data-ded-reveal="up" data-ded-delay="1">
                    <div class="stat-number" data-count="50" data-count-suffix="+">0+</div>
                    <div class="stat-label">Progetti Completati</div>
                </div>
                <div class="col-6 col-md-3 ded-stat-item" data-ded-reveal="up" data-ded-delay="2">
                    <div class="stat-number" data-count="98" data-count-suffix="%">0%</div>
                    <div class="stat-label">Clienti Soddisfatti</div>
                </div>
                <div class="col-6 col-md-3 ded-stat-item" data-ded-reveal="up" data-ded-delay="3">
                    <div class="stat-number" data-count="4" data-count-suffix=" ISO">0</div>
                    <div class="stat-label">Certificazioni ISO</div>
                </div>
                <div class="col-6 col-md-3 ded-stat-item" data-ded-reveal="up" data-ded-delay="4">
                    <div class="stat-number" data-count="2023">0</div>
                    <div class="stat-label">Anno di Fondazione</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ── SERVICES ───────────────────────────────────── -->
    <section class="ded-section ded-section-dark" id="services">
        <div class="container">
            <div class="text-center mb-5" data-ded-reveal="up">
                <span class="section-label">I Nostri Servizi</span>
                <h2 class="text-white">Soluzioni tech per ogni <span class="text-gradient">esigenza</span></h2>
                <p class="mx-auto" style="max-width:560px;color:rgba(255,255,255,.55);font-size:1.05rem;line-height:1.7;">
                    Dall'intelligenza artificiale allo sviluppo software custom,
                    offriamo un ecosistema completo di servizi IT.
                </p>
            </div>

            <div class="ded-feature-bento">
                <!-- AI Agents - wide -->
                <div class="bento-item bento-wide bento-blue" data-ded-reveal="up">
                    <div class="bento-bg-icon">🤖</div>
                    <span class="section-label" style="margin-bottom:.75rem;">01</span>
                    <h3 class="text-white mb-2">AI Agents &amp; Automazione</h3>
                    <p style="color:rgba(255,255,255,.6);margin:0;max-width:400px;">
                        Agenti AI custom per automatizzare workflow aziendali.
                        ROI misurabile, integrazione con i tuoi strumenti esistenti.
                    </p>
                </div>
                <!-- Odoo -->
                <div class="bento-item bento-orange" data-ded-reveal="up" data-ded-delay="1">
                    <div class="bento-bg-icon">⚙️</div>
                    <span class="section-label" style="margin-bottom:.75rem;">02</span>
                    <h4 class="text-white mb-2">Odoo Partner</h4>
                    <p style="color:rgba(255,255,255,.6);margin:0;font-size:.9rem;">
                        Implementazione, customizzazione e supporto Odoo ERP.
                    </p>
                </div>
                <!-- Software Dev -->
                <div class="bento-item" data-ded-reveal="up" data-ded-delay="1">
                    <div class="bento-bg-icon">💻</div>
                    <span class="section-label" style="margin-bottom:.75rem;">03</span>
                    <h4 class="text-white mb-2">Software Custom</h4>
                    <p style="color:rgba(255,255,255,.6);margin:0;font-size:.9rem;">
                        Python · React · Node.js. Soluzioni scalabili e sicure.
                    </p>
                </div>
                <!-- Mobile/Web -->
                <div class="bento-item" data-ded-reveal="up" data-ded-delay="2">
                    <div class="bento-bg-icon">📱</div>
                    <span class="section-label" style="margin-bottom:.75rem;">04</span>
                    <h4 class="text-white mb-2">App Web &amp; Mobile</h4>
                    <p style="color:rgba(255,255,255,.6);margin:0;font-size:.9rem;">
                        Progressive Web App e applicazioni native cross-platform.
                    </p>
                </div>
                <!-- Healthcare - tall -->
                <div class="bento-item bento-tall" data-ded-reveal="up" data-ded-delay="2">
                    <div class="bento-bg-icon">🏥</div>
                    <span class="section-label" style="margin-bottom:.75rem;">05</span>
                    <h4 class="text-white mb-2">Healthcare IT</h4>
                    <p style="color:rgba(255,255,255,.6);margin:0;font-size:.9rem;">
                        Soluzioni digitali per il settore sanitario. Conformità normativa,
                        sicurezza dati e integrazione con i sistemi ospedalieri.
                    </p>
                </div>
                <!-- PA -->
                <div class="bento-item" data-ded-reveal="up" data-ded-delay="3">
                    <div class="bento-bg-icon">🏛️</div>
                    <span class="section-label" style="margin-bottom:.75rem;">06</span>
                    <h4 class="text-white mb-2">Pubblica Amministrazione</h4>
                    <p style="color:rgba(255,255,255,.6);margin:0;font-size:.9rem;">
                        Digitalizzazione PA. Conformità CAD e GDPR.
                    </p>
                </div>
                <!-- Data / Dashboard -->
                <div class="bento-item" data-ded-reveal="up" data-ded-delay="3">
                    <div class="bento-bg-icon">📊</div>
                    <span class="section-label" style="margin-bottom:.75rem;">07</span>
                    <h4 class="text-white mb-2">Data &amp; Dashboard</h4>
                    <p style="color:rgba(255,255,255,.6);margin:0;font-size:.9rem;">
                        Business Intelligence e dashboard interattive data-driven.
                    </p>
                </div>
            </div>

            <div class="text-center mt-5" data-ded-reveal="up">
                <a href="/services" class="btn btn-outline-primary btn-lg btn-magnetic">
                    Esplora tutti i servizi <i class="fa fa-arrow-right ms-2"/>
                </a>
            </div>
        </div>
    </section>

    <!-- ── TECH STACK MARQUEE ─────────────────────────── -->
    <section style="padding:3rem 0;background:var(--ded-bg-mid);border-top:1px solid rgba(255,255,255,.06);">
        <div class="container mb-4">
            <p class="text-center font-mono" style="color:rgba(255,255,255,.3);font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;">
                // Technology Stack
            </p>
        </div>
        <div class="ded-marquee-wrap">
            <div class="ded-marquee">
                <!-- Duplicated for seamless loop -->
                <span class="tech-badge">🐍 Python</span>
                <span class="tech-badge">⚛️ React</span>
                <span class="tech-badge">🟢 Node.js</span>
                <span class="tech-badge">🐘 PostgreSQL</span>
                <span class="tech-badge">⚙️ Odoo 17/18/19</span>
                <span class="tech-badge">🤖 LangChain</span>
                <span class="tech-badge">🧠 OpenAI / Claude</span>
                <span class="tech-badge">☁️ AWS / Azure</span>
                <span class="tech-badge">🐳 Docker</span>
                <span class="tech-badge">🔄 n8n</span>
                <span class="tech-badge">📱 React Native</span>
                <span class="tech-badge">🔷 TypeScript</span>
                <span class="tech-badge">🐍 Python</span>
                <span class="tech-badge">⚛️ React</span>
                <span class="tech-badge">🟢 Node.js</span>
                <span class="tech-badge">🐘 PostgreSQL</span>
                <span class="tech-badge">⚙️ Odoo 17/18/19</span>
                <span class="tech-badge">🤖 LangChain</span>
                <span class="tech-badge">🧠 OpenAI / Claude</span>
                <span class="tech-badge">☁️ AWS / Azure</span>
                <span class="tech-badge">🐳 Docker</span>
                <span class="tech-badge">🔄 n8n</span>
                <span class="tech-badge">📱 React Native</span>
                <span class="tech-badge">🔷 TypeScript</span>
            </div>
        </div>
    </section>

    <!-- ── ABOUT PREVIEW ─────────────────────────────── -->
    <section class="ded-section ded-section-glass" id="about">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6" data-ded-reveal="left">
                    <!-- Code terminal effect -->
                    <div class="ded-card p-0 overflow-hidden" style="border-color:rgba(37,99,235,.2);">
                        <div style="background:rgba(0,0,0,.4);padding:.75rem 1.25rem;display:flex;align-items:center;gap:.5rem;border-bottom:1px solid rgba(255,255,255,.08);">
                            <span style="width:12px;height:12px;border-radius:50%;background:#FF5F56;"/>
                            <span style="width:12px;height:12px;border-radius:50%;background:#FFBD2E;"/>
                            <span style="width:12px;height:12px;border-radius:50%;background:#27C93F;"/>
                            <span class="font-mono ms-2" style="color:rgba(255,255,255,.35);font-size:.75rem;">ded-partners.py</span>
                        </div>
                        <div class="p-4 font-mono" style="font-size:.85rem;line-height:1.9;color:#93C5FD;">
                            <span style="color:rgba(255,255,255,.3);">01</span>  <span style="color:#F59E0B;">class</span> <span style="color:#4ADE80;">DeDPartners</span><span style="color:#fff;">:</span><br/>
                            <span style="color:rgba(255,255,255,.3);">02</span>      <span style="color:#F59E0B;">founded</span> <span style="color:#fff;">=</span> <span style="color:#FB923C;">2023</span><br/>
                            <span style="color:rgba(255,255,255,.3);">03</span>      <span style="color:#F59E0B;">location</span> <span style="color:#fff;">=</span> <span style="color:#A3E635;">"Padova, Italia"</span><br/>
                            <span style="color:rgba(255,255,255,.3);">04</span>      <span style="color:#F59E0B;">expertise</span> <span style="color:#fff;">=</span> [<br/>
                            <span style="color:rgba(255,255,255,.3);">05</span>          <span style="color:#A3E635;">"AI Agents"</span>,<br/>
                            <span style="color:rgba(255,255,255,.3);">06</span>          <span style="color:#A3E635;">"Odoo ERP"</span>,<br/>
                            <span style="color:rgba(255,255,255,.3);">07</span>          <span style="color:#A3E635;">"Software Custom"</span>,<br/>
                            <span style="color:rgba(255,255,255,.3);">08</span>          <span style="color:#A3E635;">"Healthcare IT"</span><br/>
                            <span style="color:rgba(255,255,255,.3);">09</span>      ]<br/>
                            <span style="color:rgba(255,255,255,.3);">10</span>      <span style="color:#F59E0B;">certifications</span> <span style="color:#fff;">=</span> [<span style="color:#A3E635;">"ISO 9001"</span>, <span style="color:#A3E635;">"ISO 27001"</span>, ...]<br/>
                            <span style="color:rgba(255,255,255,.3);">11</span>  <br/>
                            <span style="color:rgba(255,255,255,.3);">12</span>      <span style="color:#F59E0B;">def</span> <span style="color:#60A5FA;">innovate</span><span style="color:#fff;">(self, client):</span><br/>
                            <span style="color:rgba(255,255,255,.3);">13</span>          <span style="color:#F59E0B;">return</span> <span style="color:#A3E635;">"Digital Transformation ✓"</span>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6" data-ded-reveal="right">
                    <span class="section-label">Chi Siamo</span>
                    <h2 class="text-white mb-4">Innoviamo con <span class="text-gradient">passione</span> e precisione</h2>
                    <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:1.5rem;">
                        Siamo <strong style="color:#fff;">appassionati di tecnologia e innovazione</strong>.
                        Dal 2023 sviluppiamo soluzioni custom per soddisfare le esigenze
                        uniche dei nostri clienti pubblici e privati.
                    </p>
                    <p style="color:rgba(255,255,255,.65);line-height:1.8;margin-bottom:2rem;">
                        Utilizziamo linguaggi e framework moderni come <strong style="color:#93C5FD;">Python, React e Node.js</strong>
                        per creare applicazioni avanzate che ottimizzano i processi aziendali
                        e supportano le decisioni data-driven.
                    </p>
                    <div class="d-flex flex-wrap gap-3 mb-4">
                        <div class="d-flex align-items-center gap-2" style="color:rgba(255,255,255,.7);">
                            <i class="fa fa-check-circle" style="color:var(--ded-orange);"/>
                            Soluzioni su misura
                        </div>
                        <div class="d-flex align-items-center gap-2" style="color:rgba(255,255,255,.7);">
                            <i class="fa fa-check-circle" style="color:var(--ded-orange);"/>
                            Massima sicurezza dati
                        </div>
                        <div class="d-flex align-items-center gap-2" style="color:rgba(255,255,255,.7);">
                            <i class="fa fa-check-circle" style="color:var(--ded-orange);"/>
                            Supporto continuo
                        </div>
                        <div class="d-flex align-items-center gap-2" style="color:rgba(255,255,255,.7);">
                            <i class="fa fa-check-circle" style="color:var(--ded-orange);"/>
                            Scalabilità garantita
                        </div>
                    </div>
                    <a href="/about" class="btn btn-primary btn-lg btn-magnetic">
                        Scopri il nostro team <i class="fa fa-arrow-right ms-2"/>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ── PARTNERS / CLIENTS ─────────────────────────── -->
    <section class="ded-section" style="padding:4rem 0;background:var(--ded-bg-mid);">
        <div class="container">
            <p class="text-center font-mono mb-4" style="color:rgba(255,255,255,.3);font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;" data-ded-reveal="up">
                // Clienti &amp; Partner di Fiducia
            </p>
            <div class="partner-logo-grid" data-ded-reveal="up">
                <div class="text-center" style="color:rgba(255,255,255,.3);font-size:.9rem;font-style:italic;">
                    Regione Veneto · Università di Padova · Comune di Fara San Martino ·
                    Castiglione Messer Marino · IACP · internomare.it · Stadea · e altri
                </div>
            </div>
        </div>
    </section>

    <!-- ── CTA ───────────────────────────────────────── -->
    <section class="ded-section">
        <div class="container">
            <div class="ded-cta text-center" data-ded-reveal="up">
                <span class="section-label">Pronto a innovare?</span>
                <h2 class="text-white mb-3" style="font-size:clamp(2rem,4vw,3rem);">
                    Trasformiamo la tua idea in<br/>
                    <span class="text-gradient">realtà digitale</span>
                </h2>
                <p class="mb-5 mx-auto" style="max-width:520px;color:rgba(255,255,255,.6);font-size:1.1rem;line-height:1.7;">
                    Contattaci per una consulenza gratuita. Analizzeremo le tue esigenze
                    e proporremo la soluzione più adatta al tuo business.
                </p>
                <div class="d-flex flex-wrap gap-3 justify-content-center">
                    <a href="/contact" class="btn btn-primary btn-lg btn-magnetic">
                        <i class="fa fa-envelope me-2"/>Contattaci ora
                    </a>
                    <a href="tel:+393802104571" class="btn btn-glass btn-lg btn-magnetic">
                        <i class="fa fa-phone me-2"/>+39 380 2104571
                    </a>
                </div>
            </div>
        </div>
    </section>

</div>
</t>
    </field>
</record>

<record id="ded_home_page" model="website.page">
    <field name="name">Home</field>
    <field name="url">/</field>
    <field name="website_published">True</field>
    <field name="is_homepage">True</field>
    <field name="view_id" ref="ded_home_view"/>
</record>

</odoo>
